# Mission Control OpenClaw Integration
#
# Optional: Bearer token for POST /api/state/activity (hooks / ingest). If unset, append is open (dev only).
# MISSION_CONTROL_INGEST_TOKEN=
#
# Optional: OpenClaw daily log directory for /api/openclaw/activities and /api/openclaw/live-stream.
# OPENCLAW_LOG_DIR=C:\\tmp\\openclaw
#
# Optional: Provide a gateway token if wake endpoint requires auth.
# MISSION_CONTROL_GATEWAY_TOKEN=
#
# Optional: Override OpenClaw root path if different from default.
# OPENCLAW_ROOT=C:\\Users\\mohit\\.openclaw
#
# Optional: Override OpenClaw gateway port (default 18789).
# OPENCLAW_GATEWAY_PORT=18789
#
# Optional: Git/workspace root for experimental /api/tools/* (auto-detect walks up for .git).
# MISSION_CONTROL_WORKSPACE_ROOT=C:\\Users\\mohit\\.openclaw\\workspace
